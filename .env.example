# ============================================
# Lviv Avukat — Ortam Değişkenleri Şablonu
# ============================================
# Bu dosyayı .env.local olarak kopyalayın ve değerleri doldurun
# cp .env.example .env.local

# ---- Veritabanı (Vercel Neon PostgreSQL) ----
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# ---- NextAuth.js ----
# openssl rand -base64 32 ile üretin
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# ---- Admin Panel ----
# Gizli URL prefix — değiştirmeniz ÖNERİLİR
ADMIN_ROUTE_PREFIX=panel-yonetim2024x
NEXT_PUBLIC_ADMIN_ROUTE_PREFIX=panel-yonetim2024x

# ---- Google Vertex AI / Gemini ----
GEMINI_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# ---- Vercel Blob (Dosya Yükleme) ----
BLOB_READ_WRITE_TOKEN=

# ---- Site Ayarları ----
NEXT_PUBLIC_SITE_URL=https://lvivavukat.com
NEXT_PUBLIC_WHATSAPP_NUMBER=+380000000000
